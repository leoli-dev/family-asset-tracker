{
  "openapi": "3.1.0",
  "info": {
    "title": "Family Asset Tracker API",
    "version": "0.2.0",
    "description": "REST API for Family Asset Tracker. All endpoints require Bearer token authentication."
  },
  "paths": {
    "/api/auth/verify": {
      "get": {
        "summary": "Verify auth token",
        "operationId": "auth_verify_api_auth_verify_get",
        "responses": {
          "200": {
            "description": "Token is valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        },
        "security": [{ "HTTPBearer": [] }]
      }
    },
