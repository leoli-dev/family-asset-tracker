    },
    "/api/backup": {
      "get": {
        "summary": "Export full backup as JSON",
        "operationId": "get_backup_api_backup_get",
        "responses": {
          "200": {
            "description": "Full backup payload",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RestorePayload" }
              }
            }
          }
        },
        "security": [{ "HTTPBearer": [] }]
      }
    },
    "/api/restore": {
      "post": {
        "summary": "Restore from a full backup",
        "operationId": "post_restore_api_restore_post",
        "description": "Replaces all data with the provided backup. This is a destructive operation.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RestorePayload" }
            }
          }
        },
        "responses": {
          "204": { "description": "Restore successful" },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        },
        "security": [{ "HTTPBearer": [] }]
      }
    },
    "/api/export/csv": {
      "get": {
        "summary": "Export all records as CSV",
        "operationId": "get_export_csv_api_export_csv_get",
        "description": "Returns a CSV file with all records joined with account, owner, and category names.",
        "responses": {
          "200": {
            "description": "CSV file",
            "content": {
              "text/csv": {
                "schema": { "type": "string" }
              }
            }
          }
        },
        "security": [{ "HTTPBearer": [] }]
      }
    }
  },
  "components": {
    "schemas": {
      "Owner": {
        "type": "object",
        "title": "Owner",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "name": { "type": "string", "title": "Name" }
        }
      },
      "OwnerCreate": {
        "type": "object",
        "title": "OwnerCreate",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "name": { "type": "string", "title": "Name" }
        }
      },
      "OwnerUpdate": {
        "type": "object",
        "title": "OwnerUpdate",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "title": "Name" }
        }
      },
      "Category": {
        "type": "object",
        "title": "Category",
        "required": ["id", "name", "type", "color"],
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "name": { "type": "string", "title": "Name" },
          "type": {
            "type": "string",
            "enum": ["ASSET", "LIABILITY"],
            "title": "Type"
          },
          "color": {
            "type": "string",
            "title": "Color",
            "description": "Hex color string, e.g. #10b981"
          }
        }
      },
      "CategoryCreate": {
        "type": "object",
        "title": "CategoryCreate",
        "required": ["id", "name", "type", "color"],
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "name": { "type": "string", "title": "Name" },
          "type": { "type": "string", "enum": ["ASSET", "LIABILITY"], "title": "Type" },
          "color": { "type": "string", "title": "Color" }
        }
      },
      "CategoryUpdate": {
        "type": "object",
        "title": "CategoryUpdate",
        "properties": {
          "name": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "Name" },
          "type": {
            "anyOf": [
              { "type": "string", "enum": ["ASSET", "LIABILITY"] },
              { "type": "null" }
            ],
            "title": "Type"
          },
          "color": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "Color" }
        }
      },
      "Account": {
        "type": "object",
        "title": "Account",
        "required": ["id", "name", "currency", "categoryId", "ownerId"],
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "name": { "type": "string", "title": "Name" },
          "currency": { "type": "string", "title": "Currency", "description": "ISO 4217 currency code, e.g. USD, CAD, CNY" },
          "categoryId": { "type": "string", "title": "CategoryId" },
          "ownerId": { "type": "string", "title": "OwnerId" }
        }
      },
      "AccountCreate": {
        "type": "object",
        "title": "AccountCreate",
        "required": ["id", "name", "currency", "categoryId", "ownerId"],
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "name": { "type": "string", "title": "Name" },
          "currency": { "type": "string", "title": "Currency" },
          "categoryId": { "type": "string", "title": "CategoryId" },
          "ownerId": { "type": "string", "title": "OwnerId" }
        }
      },
      "AccountUpdate": {
        "type": "object",
        "title": "AccountUpdate",
        "properties": {
          "name": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "Name" },
          "currency": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "Currency" },
          "categoryId": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "CategoryId" },
          "ownerId": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "OwnerId" }
        }
      },
      "AssetRecord": {
        "type": "object",
        "title": "AssetRecord",
        "required": ["id", "date", "accountId", "amount", "timestamp"],
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "date": { "type": "string", "format": "date", "title": "Date", "description": "YYYY-MM-DD" },
          "accountId": { "type": "string", "title": "AccountId" },
          "amount": { "type": "number", "title": "Amount" },
          "timestamp": { "type": "integer", "title": "Timestamp", "description": "Unix milliseconds, used as tiebreaker when sorting same-date records" },
          "note": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Note"
          }
        }
      },
      "RecordCreate": {
        "type": "object",
        "title": "RecordCreate",
        "required": ["id", "date", "accountId", "amount", "timestamp"],
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "date": { "type": "string", "format": "date", "title": "Date" },
          "accountId": { "type": "string", "title": "AccountId" },
          "amount": { "type": "number", "title": "Amount" },
          "timestamp": { "type": "integer", "title": "Timestamp" },
          "note": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Note"
          }
        }
      },
      "RecordUpdate": {
        "type": "object",
        "title": "RecordUpdate",
        "properties": {
          "date": { "anyOf": [{ "type": "string", "format": "date" }, { "type": "null" }], "title": "Date" },
          "accountId": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "AccountId" },
          "amount": { "anyOf": [{ "type": "number" }, { "type": "null" }], "title": "Amount" },
          "timestamp": { "anyOf": [{ "type": "integer" }, { "type": "null" }], "title": "Timestamp" },
          "note": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "Note" }
        }
      },
      "Settings": {
        "type": "object",
        "title": "Settings",
        "properties": {
          "defaultCurrency": { "type": "string", "title": "DefaultCurrency" },
          "language": {
            "type": "string",
            "enum": ["EN", "FR", "ZH"],
            "title": "Language"
          }
        }
      },
      "SettingsUpdate": {
        "type": "object",
        "title": "SettingsUpdate",
        "properties": {
          "defaultCurrency": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "DefaultCurrency" },
          "language": {
            "anyOf": [
              { "type": "string", "enum": ["EN", "FR", "ZH"] },
              { "type": "null" }
            ],
            "title": "Language"
          }
        }
      },
      "RestorePayload": {
        "type": "object",
        "title": "RestorePayload",
        "required": ["records", "accounts", "categories", "owners"],
        "properties": {
          "metadata": {
            "anyOf": [{ "additionalProperties": true, "type": "object" }, { "type": "null" }],
            "title": "Metadata"
          },
          "records": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AssetRecord" },
            "title": "Records"
          },
